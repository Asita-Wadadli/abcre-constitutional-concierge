# A.B.C.R.E. Constitutional Concierge - Environment Configuration

# API Keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Stripe (for payments)
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Database (optional - can use JSON files initially)
DATABASE_URL=optional_postgresql_url

# JWT Secret (generate random string)
JWT_SECRET=your_random_jwt_secret_here

# Pricing Tiers (monthly in cents)
PRICE_BASIC=499
PRICE_PRO=1499
PRICE_ORG=4999
PRICE_INST=14999

# Revenue Split (percentage to ABCRE)
ABCRE_REVENUE_SHARE=40

# Branding
BRAND_NAME=A.B.C.R.E. Constitutional Concierge
BRAND_URL=https://myabcre.org
SUPPORT_EMAIL=support@myabcre.org

# Features
ENABLE_FREE_TIER=true
FREE_QUERIES_PER_DAY=3
ENABLE_ANALYTICS=true

# African-Centered Perspective
SYSTEM_PERSONA=african_centered_legal_educator